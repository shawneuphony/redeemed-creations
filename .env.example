# ── Database (Turso) — get from app.turso.tech ───────────────────────────────
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=

# ── Payload ───────────────────────────────────────────────────────────────────
PAYLOAD_SECRET=

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Secrets ───────────────────────────────────────────────────────────────────
CRON_SECRET=
PREVIEW_SECRET=

# ── Vercel Blob — get from Vercel → Storage → your store → Tokens ─────────────
BLOB_READ_WRITE_TOKEN=
